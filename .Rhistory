# Required packages
library(ggplot2)
library(dplyr)
library(scales)
# Grid for debt (x axis)
debt <- seq(0, 100, by = 1)
# Risk-acceptant (convex) response: use a convex transform and rescale to (0,1)
convex_raw <- function(x, power = 2.0) (x^power) / max(debt^power)
prob_convex <- function(x, power = 2.0, low = 0.01, high = 0.99) {
scaled <- convex_raw(x, power = power)
scales::rescale(scaled, to = c(low, high))
}
# Data frame of the curve
df <- tibble(debt = debt, prob = prob_convex(debt, power = 2.2))
# Choose two example x values and compute exact prob on the curve with interpolation
points_x <- c(25, 40)
points_df <- tibble(debt = points_x) %>%
rowwise() %>%
mutate(
prob = approx(x = df$debt, y = df$prob, xout = debt)$y,
label = c("A", "B")[which(points_x == debt)]
) %>%
ungroup() %>%
mutate(label_y = pmax(prob - 0.04, 0))  # label placed slightly below the point
# Plot
p <- ggplot(df, aes(x = debt, y = prob)) +
geom_line(color = "#d62728", size = 1.2) +
# solid red points placed exactly at (debt, prob) on the curve
geom_point(data = points_df, aes(x = debt, y = prob),
color = "#d62728", size = 3.5, shape = 19) +
# label placed directly below each point using label_y
geom_text(data = points_df, aes(x = debt, y = label_y, label = label),
color = "black", size = 3.8, fontface = "bold", vjust = 1) +
# dashed projection lines that terminate exactly at the curve points
geom_segment(data = points_df, aes(x = debt, xend = debt, y = 0, yend = prob),
linetype = "dashed", color = "gray40") +
geom_segment(data = points_df, aes(x = 0, xend = debt, y = prob, yend = prob),
linetype = "dashed", color = "gray40") +
# axis labels and limits: numeric 0-1 (no percent sign)
scale_y_continuous(labels = number_format(accuracy = 0.01), limits = c(0, 1)) +
labs(
x = "Level of debt",
y = "P(Voting for Non-Incumbent)",
title = ""
) +
theme_minimal(base_size = 13) +
theme(plot.title = element_text(face = "bold"))
# numeric labels at projected axis intersections
p <- p +
geom_text(data = points_df, aes(x = debt, y = 0, label = paste0("x=", debt)),
vjust = 1.6, color = "gray20", size = 3.2) +
geom_text(data = points_df, aes(x = 0, y = prob, label = paste0("p=", sprintf("%.2f", prob))),
hjust = -0.05, color = "gray20", size = 3.2)
# Keep axis ranges exactly 0-1 and 0-100
p <- p + coord_cartesian(xlim = c(0, 100), ylim = c(0, 1), expand = FALSE)
# Print plot
print(p)
